# cc — runtime + local artifacts
runs/
*.zip
__pycache__/
*.pyc
.pytest_cache/
.coverage
htmlcov/
# project venv lives at .venv/ in the project root
.venv/

# Config-page backups — the config store snapshots the prior file to <root>/.bak/
# (e.g. yamls/default/fleet/.bak/, yamls/default/commands/.bak/, …) on every save.
.bak/

# Config profiles (P8) — the active-profile marker is a LOCAL runtime choice (which
# editable-YAML set is live on this base station), not shared. The profile config dirs
# themselves (yamls/default/, yamls/<name>/, …) ARE tracked.
yamls/active

# Rebuild system (the Compiler) — generated artifacts
# (gitignore has no inline comments: each pattern must be on its own line)
apps/
.compiler-manifest.json
compile-report.md
todo
